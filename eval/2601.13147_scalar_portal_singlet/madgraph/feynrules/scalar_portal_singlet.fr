(* FeynRules model file for Singlet Fermion DM + Scalar Portal *)
(* arXiv:2601.13147 — Das, Niyogi, Srivastava *)
(* FeynRules 2.3 compatible *)
(* NOTE: This .fr file encodes the paper's Lagrangian as comments. *)
(* A complete compilable version requires FeynRules 2.3 in Mathematica. *)

(* ============================================================ *)
(* Model Description                                           *)
(* ============================================================ *)
(*
   Lagrangian (Eqs. 1-8 of arXiv:2601.13147):

   L = L_SM + L_scalar + L_DM + L_portal

   L_scalar = (1/2)(partial_mu S)^2 - V(H, S)

   V(H, S) = -mu_h^2 H†H + lambda_h (H†H)^2
             + mu_hs H†H S + (1/2) mu_s^2 S^2
             + (1/3) mu_3 S^3 + (1/4) lambda_s S^4
             + (1/2) lambda_hs (H†H) S^2                     (Eq. 4)

   L_DM = chi_bar (i gamma^mu partial_mu - M_chi) chi

   L_portal = g_chi S chi_bar chi                             (Eq. 7)

   After EWSB with H = (v_h + h)/sqrt(2):
   - CP-even mass matrix (Eq. 8):
     M^2 = [[2 lambda_h v_h^2,  mu_hs v_h],
             [mu_hs v_h,         mu_s^2 + (1/2) lambda_hs v_h^2]]
   - Mass eigenstates h1 (SM-like), h2 (singlet-like) via mixing angle theta
*)

(* ============================================================ *)
(* FeynRules Syntax (partial, requires FR package) *)
(* ============================================================ *)

M$ModelName = "ScalarPortalSinglet";
M$Information = {
  Authors -> {"Das, Niyogi, Srivastava"},
  Institutions -> {},
  Emails -> {},
  URLs -> "https://arxiv.org/abs/2601.13147",
  Version -> "1.0",
  Date -> "2026-04-18",
  References -> {"arXiv:2601.13147"}
};

(* Gauge group: Standard Model only *)
M$GaugeGroups = {
  (* SM gauge groups inherited *)
};

(* ============================================================ *)
(* Index Definitions *)
(* ============================================================ *)

IndexRange[Index[Colour]] = Unfold[Range[3]];
IndexRange[Index[Generation]] = Range[3];

(* ============================================================ *)
(* New Parameters *)
(* ============================================================ *)

M$Parameters = {
  (* DM Yukawa coupling *)
  gchi == {
    ParameterType -> External,
    Value -> 0.57,
    TeX -> "g_\chi",
    Description -> "DM-singlet Yukawa coupling"
  },
  (* Singlet quartic *)
  lambdas == {
    ParameterType -> External,
    Value -> 3.38,
    TeX -> "\lambda_s",
    Description -> "Singlet quartic self-coupling"
  },
  (* Portal quartic *)
  lambdahs == {
    ParameterType -> External,
    Value -> 2.2,
    TeX -> "\lambda_{hs}",
    Description -> "H^dagger H S^2 portal coupling"
  },
  (* Singlet-Higgs linear mixing *)
  muhs == {
    ParameterType -> External,
    Value -> 0.0,
    TeX -> "\mu_{hs}",
    Description -> "H^dagger H S linear mixing [GeV]"
  },
  (* Singlet mass^2 *)
  mus2 == {
    ParameterType -> External,
    Value -> 40000.0,
    TeX -> "\mu_s^2",
    Description -> "Singlet bare mass squared [GeV^2]"
  },
  (* Singlet cubic *)
  mu3 == {
    ParameterType -> External,
    Value -> -20.0,
    TeX -> "\mu_3",
    Description -> "Singlet cubic coupling [GeV]"
  }
};

(* ============================================================ *)
(* New Fields *)
(* ============================================================ *)

M$ClassesDescription = {
  (* Real singlet scalar S *)
  S[1] == {
    ClassName -> SS,
    SelfConjugate -> True,
    Mass -> {MS, 200.0},
    Width -> {WS, 0.0},
    TeX -> "S",
    Description -> "Singlet scalar portal"
  },
  (* Dirac fermion DM chi *)
  F[16] == {
    ClassName -> chi,
    SelfConjugate -> False,
    Mass -> {Mchi, 222.0},
    Width -> {Wchi, 0.0},
    TeX -> "\chi",
    QuantumNumbers -> {LeptonNumber -> 0, Q -> 0},
    Description -> "Singlet fermion DM"
  }
};

(* ============================================================ *)
(* Lagrangian *)
(* ============================================================ *)

(* Singlet kinetic + self-coupling *)
LsingletKin := (1/2) del[SS, mu] del[SS, mu];
LsingletSelf := -(1/2) mus2 SS^2 - (1/3) mu3 SS^3 - (1/4) lambdas SS^4;

(* Portal terms (at vs=0, linear term is mu_hs H†H S) *)
(* These mix into the CP-even mass matrix after EWSB *)
LportalScalar := -muhs HC[Phi].Phi SS - (1/2) lambdahs HC[Phi].Phi SS^2;

(* DM kinetic *)
LDMkin := I chibar.Ga[mu].del[chi, mu] - Mchi chibar.chi;

(* DM portal *)
LDMportal := -gchi SS chibar.chi;

(* Full new-physics Lagrangian *)
LNewPhysics := LsingletKin + LsingletSelf + LportalScalar + LDMkin + LDMportal;
