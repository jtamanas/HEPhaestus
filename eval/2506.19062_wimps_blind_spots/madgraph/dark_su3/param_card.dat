  15  1.777000e+00  # MTA
  ## Dark sector
  9000001  2.000000e+02  # MV (dark vector boson, DM)
  9000002  1.500000e+02  # MPsi (dark pseudoscalar, DM)
  9000003  3.000000e+02  # MH2 (dark Higgs)
  9000004  0.000000e+00  # MV3 (unbroken SU(2) massless gauge bosons — confined)

Block DARKINPUTS
   1  1.000000e+00  # g_tilde (dark SU(3) gauge coupling)
