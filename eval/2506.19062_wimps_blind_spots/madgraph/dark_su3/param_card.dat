######################################################################
## MadGraph5 param_card for Dark SU(3) Model
## arXiv:2506.19062 — Benchmark from Figure 7/8
##
## Parameters:
##   g_tilde = 1.0 (dark gauge coupling)
##   sin_theta = 0.1 (scalar mixing)
##   m_H2 = 300 GeV (dark Higgs)
##   m_V = 200 GeV (vector DM)
##   m_Psi = 150 GeV (scalar DM, from m_V relation)
