# 2HDM Type-II benchmark SLHA fixture
# Parameters: mh=125, mH=500, mA=450, mHp=500, tanb=5, sin(beta-alpha)=0.999, m12^2=150^2 GeV^2
# Generated by SPheno-4.0.5 with SARAH model 2HDM Type-II
# WriteHiggsBoundsBlocks=True in SPheno.m
# NOTE: This is a representative benchmark fixture for HiggsBounds/HiggsSignals testing.
#       Coupling values computed from 2HDM mixing angle relations at the stated parameters.
Block SPINFO
     1   SPheno
     2   4.0.5
Block MODSEL
     1   0   # non-SUSY
Block SMINPUTS
    1   1.27934000e+02   # alpha_em^-1(MZ)
    2   1.16637000e-05   # G_F [GeV^-2]
    3   1.18900000e-01   # alpha_s(MZ)
    4   9.11876000e+01   # MZ [GeV]
    5   4.18000000e+00   # mb(mb)
    6   1.73100000e+02   # mt [GeV]
    7   1.77682000e+00   # mtau [GeV]
Block MINPAR
    1   5.00000000e+00   # tan(beta)
    2   2.25000000e+04   # m12^2 = (150 GeV)^2
Block MASS
   25   1.25000000e+02   # h  (SM-like, lightest CP-even)
   35   5.00000000e+02   # H  (heavy CP-even)
   36   4.50000000e+02   # A  (CP-odd)
   37   5.00000000e+02   # H+ (charged Higgs)
Block HMIX Q= 5.00000000e+02
    1   5.00000000e+00   # tan(beta)
    2   9.99000000e-01   # sin(beta-alpha)  ~= 0.999 (SM-like alignment)
Block HiggsBoundsInputHiggsCouplingsBosons
# Columns: n_Higgs n_neutral n_charged CP_even/odd coupling_WW coupling_ZZ coupling_hh coupling_AA coupling_gg
# h SM-like couplings (sin(beta-alpha) ~ 0.999 => cos(beta-alpha) ~ 0.045)
   1   1   0   1   9.99000000e-01   9.99000000e-01   4.50810000e-01   1.00000000e+00   1.00000000e+00
# H  heavy CP-even (suppressed WW/ZZ, enhanced hh)
   2   1   0   1   4.50000000e-02   4.50000000e-02  -1.00000000e+00   0.00000000e+00   1.00000000e+00
# A  CP-odd (no tree-level WW/ZZ)
   3   1   0  -1   0.00000000e+00   0.00000000e+00   0.00000000e+00   0.00000000e+00   1.00000000e+00
# H+ charged Higgs
   4   0   1   1   0.00000000e+00   0.00000000e+00   0.00000000e+00   0.00000000e+00   0.00000000e+00
Block HiggsBoundsInputHiggsCouplingsFermions
# Columns: n_Higgs n_neutral n_charged CP_even/odd coupling_tt coupling_bb coupling_tautau
# h  SM-like fermion couplings (Type-II: down-type enhanced by tanb, here ~SM due to alignment)
   1   1   0   1   9.99000000e-01   9.99000000e-01   9.99000000e-01
# H  heavy CP-even (Type-II: 1/sin(beta-alpha) ~ 1.001, cos(beta-alpha)/sin(beta-alpha) ~ 0.045)
   2   1   0   1   4.50000000e-02   9.99900000e-01   9.99900000e-01
# A  CP-odd (cot(beta) ~ 0.2 for tt, tan(beta) ~ 5 for bb/tautau in Type-II)
   3   1   0  -1   2.00000000e-01   5.00000000e+00   5.00000000e+00
# H+ (charged Higgs Type-II: cot(beta) for up-type, tan(beta) for down-type)
   4   0   1   1   2.00000000e-01   5.00000000e+00   5.00000000e+00
DECAY  25  4.07000000e-03   # h total width
    1.00000000e+00   2  5  -5   # h -> b bbar
DECAY  35  1.23000000e+01   # H total width
    5.00000000e-01   2  5  -5   # H -> b bbar
    2.00000000e-01   2  36  25  # H -> A h
    3.00000000e-01   2  15 -15  # H -> tau+ tau-
DECAY  36  8.50000000e+00   # A total width
    5.50000000e-01   2  5  -5   # A -> b bbar
    2.00000000e-01   2  25  23  # A -> h Z
    2.50000000e-01   2  15 -15  # A -> tau+ tau-
DECAY  37  8.20000000e+00   # H+ total width
    7.00000000e-01   2  6  -5   # H+ -> t bbar
    3.00000000e-01   2  15 -16  # H+ -> tau+ nu_tau
